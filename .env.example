# Production Environment Variables for Render Deployment
# Copy these to Render's environment variables section

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_generated_secret_key_here

# Database URL (Render provides PostgreSQL connection string automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mail configuration (optional - only if you need email features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Port (Render sets this automatically, but can override)
PORT=5000
